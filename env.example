# Cesium Ion Token - Get your token from https://ion.cesium.com/
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Cesium Base URL for static assets
NEXT_PUBLIC_CESIUM_BASE_URL=/cesium

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/pedx_visualizer

# Optional: Database connection pool settings
DB_POOL_MIN=0
DB_POOL_MAX=10
# Optional: Database timeouts in milliseconds
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000

# GeoNames API Configuration
# Register a free username at https://www.geonames.org/login (the shared
# "demo" account is heavily throttled/disabled, so set your own).
GEONAMES_USERNAME=your_geonames_username_here
